# =============================================================
# Dušan Stil Dashboard — environment varijable
# Prepiši ovaj fajl u .env.local i popuni sve vrednosti.
# =============================================================

# --- Supabase (obavezno) ---
# Iz Supabase Dashboard → Settings → API → "Project URL" i "anon public" ključ
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- PIN-ovi (fallback ako baza padne) ---
# Stvarni PIN-ovi se cuvaju u Supabase tabeli auth_config; ovo su default vrednosti.
ADMIN_PIN=4986
TIM_PIN_D1=1205
TIM_PIN_D2=7501
TIM_PIN_D4=4332
TIM_PIN_D5=1172

# --- Email (Resend) ---
# Iz Resend Dashboard -> API Keys -> Create API Key
RESEND_API_KEY=re_...

# Email koji prima kod za potvrdu promene PIN-a
NOTIFY_EMAIL=dusan@dusanstil.rs

# Posiljalac. Dok ne verifikujes svoj domen kod Resend-a, ostavi default:
FROM_EMAIL=Dusan Stil <onboarding@resend.dev>
